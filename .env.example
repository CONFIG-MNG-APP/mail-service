# ==========================================
# ABAP19 Mail Service - Environment Config
# ==========================================
# Copy this file to .env and fill in real values.
# On Render.com: add these as Environment Variables in the dashboard.

# --- Gmail SMTP (required) ---
# Use Gmail App Password (16 chars, NOT your regular password)
# Create at: https://myaccount.google.com/apppasswords
GMAIL_USER=your.email@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# --- API Key (protects /api/notify endpoint) ---
# Pick any random string. FE apps must send this in x-api-key header.
API_KEY=abap19-mail-secret-key-change-me

# --- Admin Password (for /admin web UI) ---
# Pick a strong password. Used to login to the management UI.
ADMIN_PASSWORD=change-me-to-strong-password

# --- Default recipients (optional fallback) ---
# If recipients.json doesn't exist, these env values are used.
# Comma-separated list of emails.
# Manager: receives SUBMITTED, PROMOTED, ROLLED_BACK
MAIL_MANAGER=manager@example.com

# Key User: receives APPROVED, REJECTED, PROMOTED, ROLLED_BACK
MAIL_KEY_USER=user1@example.com,user2@example.com

# IT Admin: receives ACTIVE
MAIL_IT_ADMIN=admin@example.com

# --- Server port (Render.com sets this automatically) ---
PORT=3000
